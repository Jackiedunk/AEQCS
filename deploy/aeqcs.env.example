# Copy to /etc/aeqcs/aeqcs.env on Linux hosts.
# Keep this file readable only by the aeqcs service user and root.

AEQCS_ENV=production
AEQCS_LOG_LEVEL=INFO

# Main PostgreSQL/TimescaleDB connection used by batch, intraday, maintenance,
# and admin verification scripts. Use a role with the full AEQCS schema grants.
AEQCS_PG_DSN=postgresql://aeqcs_core:CHANGE_ME_AEQCS_CORE@127.0.0.1:5432/aeqcs

# Restricted PostgreSQL role used only by the MCP HTTP/SSE server.
AEQCS_CORE_PG_DSN=postgresql://aeqcs_mcp:CHANGE_ME_AEQCS_MCP@127.0.0.1:5432/aeqcs
AEQCS_MCP_POOL_SIZE=8

# MCP transport exposed to Hermes or another trusted local client.
AEQCS_MCP_TRANSPORT=sse
AEQCS_MCP_HOST=127.0.0.1
AEQCS_MCP_PORT=8000

# Local fallback root used only when AEQCS_CORE_PG_DSN/AEQCS_PG_DSN is absent.
AEQCS_LOCAL_ROOT=/data/aeqcs/local

# Data source credentials.
# Tushare remains the only PIT financial/fundamental source.
TUSHARE_TOKEN=CHANGE_ME

# Restore rehearsal target. Point this at an isolated database, never production.
AEQCS_RESTORE_PG_DSN=postgresql://aeqcs_restore:CHANGE_ME_AEQCS_RESTORE@127.0.0.1:5432/aeqcs_restore

# Optional verification-specific aliases. Keep these pointed at a disposable
# or restricted target appropriate for each verification command.
AEQCS_ALERT_PG_DSN=postgresql://aeqcs_mcp:CHANGE_ME_AEQCS_MCP@127.0.0.1:5432/aeqcs
AEQCS_RECOVERY_PG_DSN=postgresql://aeqcs_mcp:CHANGE_ME_AEQCS_MCP@127.0.0.1:5432/aeqcs
